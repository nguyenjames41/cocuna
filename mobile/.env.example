# Cocuna — mother app (Expo at mobile/)
# Copy to mobile/.env and fill in values. NEVER commit mobile/.env.

# Supabase (EXPO_PUBLIC_ prefix makes these available client-side)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Edge Function name (defaults to "cocuna-rad" if unset)
EXPO_PUBLIC_RAD_FUNCTION=cocuna-rad

# Demo seeding — when "true", auto-onboard a Maria account on first load
EXPO_PUBLIC_DEMO_MODE=true

# NOTE: ANTHROPIC_API_KEY is NOT here — the mobile client never calls Anthropic
# directly. Set it as a Supabase Edge Function secret instead:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
