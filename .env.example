# Cocuna — clinic dashboard (Next.js at repo root)
# Copy to .env (root) and fill in values. NEVER commit .env.

# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only — used by server actions / route handlers)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic — used only by server-side code (or Edge Functions)
# Per blueprint: never paste into chat. Drop here, .env stays untracked.
ANTHROPIC_API_KEY=sk-ant-...
